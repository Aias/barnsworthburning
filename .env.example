# Postgres connection for the Red Cliff Record database.
# Dev: a local clone kept fresh via `rcr db clone-prod-to-dev`.
# Prod: the mac mini's database via a read-only role.
DATABASE_URL="postgresql://user:password@localhost:5432/redcliffrecord"

# Optional. Base URL of the Red Cliff Record app; enables the
# "Open in Red Cliff Record" button on record cards.
# PUBLIC_RCR_URL="https://rcr.example.com"
